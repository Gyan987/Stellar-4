# Soroban contract deployment template
# Use these values with Soroban CLI while deploying the contract.

SOROBAN_NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Source account secret used by Soroban CLI deploy command
SOROBAN_SOURCE_SECRET=replace_with_testnet_source_secret

# Fill after deployment
SOROBAN_CONTRACT_ID=